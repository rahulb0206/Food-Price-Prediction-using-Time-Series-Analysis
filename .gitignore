# ── Data ──────────────────────────────────────────────────────────────────
# Keep data/raw and data/processed tracked (synthetic, not sensitive)
# But exclude any large or external data files added later
*.csv.gz
*.parquet
*.feather

# ── Model artifacts ────────────────────────────────────────────────────────
# Models are large binaries — regenerate with src/train.py
outputs/models/*.pkl
outputs/models/*.h5

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Virtual environments ───────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── OS junk ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
Desktop.ini
*.swp
*.swo

# ── IDE ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace

# ── Local-only files ───────────────────────────────────────────────────────
INTERVIEW_PREP.md
*.local.*

# ── Old scripts (superseded by src/) ──────────────────────────────────────
main/

